NODE_ENV=development
API_PORT=4000
# Required: Supabase Postgres connection string (session pooler or direct connection).
SUPABASE_DB_URL=
# Optional DB tuning:
DB_SSL=
DB_SSL_REJECT_UNAUTHORIZED=true
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=10000
DB_QUERY_TIMEOUT_MS=15000
DB_STATEMENT_TIMEOUT_MS=20000
DB_MAX_RETRIES=1
DB_RETRY_DELAY_MS=250
HTTP_REQUEST_TIMEOUT_MS=30000
HTTP_HEADERS_TIMEOUT_MS=35000
HTTP_KEEP_ALIVE_TIMEOUT_MS=5000
BIZERBA_AUTO_PROCESS_INTERVAL_MS=60000
BIZERBA_AUTO_PROCESS_BATCH_SIZE=500
BIZERBA_AUTO_PROCESS_MAX_ROWS_PER_LINE=5000
# Optional: route Bizerba backsync through Supabase Edge Functions.
# Example: https://<project-ref>.supabase.co/functions/v1
BIZERBA_BACKSYNC_EDGE_URL=
# Shared secret sent as `x-backsync-key` to edge backsync functions.
BIZERBA_BACKSYNC_EDGE_KEY=
BIZERBA_BACKSYNC_EDGE_REQUEST_TIMEOUT_MS=45000
# Use a random 32+ character secret.
JWT_SECRET=replace-with-a-32-plus-char-random-secret
JWT_EXPIRES_IN=12h
# Single origin (legacy):
FRONTEND_ORIGIN=http://localhost:8080
# Multiple allowed origins (comma-separated), takes precedence over FRONTEND_ORIGIN:
# FRONTEND_ORIGINS=http://localhost:8080,https://example-manager.netlify.app,https://example-supervisor.netlify.app
